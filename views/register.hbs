{{#> layout title="Registro - KanbanPro"}}
  <section class="d-flex justify-content-center py-5">
    <div class="glass p-4 w-100 auth-card">
      <h1 class="h3 fw-bold mb-1">Crear cuenta</h1>
      <p class="text-white-50 mb-4">Regístrate para comenzar.</p>

      {{#if error}}
        <div class="alert alert-danger py-2">{{error}}</div>
      {{/if}}

      <form class="d-grid gap-3" method="POST" action="/register">
        <div>
          <label class="form-label text-white-75">Nombre</label>
          <input
            class="form-control glass-input"
            type="text"
            name="nombre"
            placeholder="Tu nombre"
            value="{{values.nombre}}"
            required
          >
        </div>

        <div>
          <label class="form-label text-white-75">Email</label>
          <input
            class="form-control glass-input"
            type="email"
            name="email"
            placeholder="tu@email.com"
            value="{{values.email}}"
            required
          >
        </div>

        <div>
          <label class="form-label text-white-75">Password</label>
          <input
            class="form-control glass-input"
            type="password"
            name="password"
            placeholder="Crea una contraseña"
            required
          >
        </div>

        <button class="btn btn-gradient w-100" type="submit">Crear cuenta</button>

        <p class="text-center text-white-50 small mb-0">
          ¿Ya tienes cuenta? <a class="kp-link" href="/login">Inicia sesión</a>
        </p>
      </form>
    </div>
  </section>
{{/layout}}