{{#> layout title="Login - KanbanPro"}}
  <section class="d-flex justify-content-center py-5">
    <div class="glass p-4 w-100 auth-card">
      <h1 class="h3 fw-bold mb-1">Iniciar sesión</h1>
      <p class="text-white-50 mb-4">Accede al prototipo de KanbanPro.</p>

      {{#if error}}
        <div class="alert alert-danger py-2">{{error}}</div>
      {{/if}}

      <form class="d-grid gap-3" method="POST" action="/login">
        <div>
          <label class="form-label text-white-75">Email</label>
          <input
            class="form-control glass-input"
            type="email"
            name="email"
            placeholder="tu@email.com"
            value="{{values.email}}"
            required
          >
        </div>

        <div>
          <label class="form-label text-white-75">Password</label>
          <input
            class="form-control glass-input"
            type="password"
            name="password"
            placeholder="••••••••"
            required
          >
        </div>

        <button class="btn btn-gradient w-100" type="submit">Ingresar</button>

        <p class="text-center text-white-50 small mb-0">
          ¿No tienes cuenta? <a class="kp-link" href="/register">Regístrate</a>
        </p>
      </form>
    </div>
  </section>
{{/layout}}